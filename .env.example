# =============================================================================
# yuleASR Configurator — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -- Database -----------------------------------------------------------------

# PostgreSQL connection string (Docker Compose uses the internal hostname "postgres")
DATABASE_URL="postgres://yuleasr:changeme@postgres:5432/yuleasr"

# PostgreSQL password (used by docker-compose.yml to set POSTGRES_PASSWORD)
DB_PASSWORD=changeme

# -- API Server ---------------------------------------------------------------

PORT=3000
HOST=0.0.0.0

# JWT secret — change to a strong random string in production
JWT_SECRET=change-this-in-production

# Frontend URL (for redirect URLs in payment flow)
FRONTEND_URL=http://localhost:5173

# API server port mapping (Docker host port)
API_PORT=3000

# -- Payment (LemonSqueezy) ---------------------------------------------------

# Payment mode: "mock" (default, no config needed) | "live"
# When set to "mock", all payment endpoints work without any API key.
# Set to "live" and configure the vars below to use LemonSqueezy.
PAYMENT_MODE=mock

# LemonSqueezy API Key — get from https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=

# LemonSqueezy Store ID — get from Store Settings page
LEMONSQUEEZY_STORE_ID=

# LemonSqueezy Webhook Secret — set in Store Settings -> Webhooks
LEMONSQUEEZY_WEBHOOK_SECRET=

# LemonSqueezy Variant IDs — get from Products -> Variants page
LEMON_VARIANT_ID_MONTHLY=
LEMON_VARIANT_ID_YEARLY=
