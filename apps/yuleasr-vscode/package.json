{
  "name": "yuleasr-vscode",
  "displayName": "yuleASR Configurator",
  "description": "Visual configuration editor for yuleASR AutoSAR modules",
  "version": "0.1.0",
  "publisher": "yuletech",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/frisky1985/yuleASR-Configurator.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Formatters"
  ],
  "keywords": [
    "yuleASR",
    "AutoSAR",
    "BSW",
    "embedded",
    "configuration"
  ],
  "activationEvents": [
    "onLanguage:json",
    "workspaceContains:**/*.yule.json",
    "workspaceContains:**/*.xdm",
    "workspaceContains:**/yuleasr.config.json",
    "onCommand:yuleasr.openConfig"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "yuleasr.openConfig",
        "title": "Open Configuration",
        "icon": "$(open-editors-view-icon)"
      },
      {
        "command": "yuleasr.openDashboard",
        "title": "Open yuleASR Configurator",
        "icon": "$(dashboard)"
      },
      {
        "command": "yuleasr.refreshExplorer",
        "title": "Refresh Explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "yuleasr.syncConfig",
        "title": "Sync with yuleASR",
        "icon": "$(sync)"
      },
      {
        "command": "yuleasr.validateConfig",
        "title": "Validate Configuration",
        "icon": "$(check)"
      },
      {
        "command": "yuleasr.generateCode",
        "title": "Generate Code",
        "icon": "$(gear)"
      },
      {
        "command": "yuleasr.newModule",
        "title": "New Module",
        "icon": "$(new-file)"
      },
      {
        "command": "yuleasr.deleteModule",
        "title": "Delete Module",
        "icon": "$(trash)"
      },
      {
        "command": "yuleasr.renameModule",
        "title": "Rename Module",
        "icon": "$(edit)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "yuleasr.openConfig",
          "when": "workspaceHasYuleASR"
        }
      ],
      "view/title": [
        {
          "command": "yuleasr.newModule",
          "when": "view == yuleasrExplorer",
          "group": "navigation"
        },
        {
          "command": "yuleasr.refreshExplorer",
          "when": "view == yuleasrExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "yuleasr.openConfig",
          "when": "view == yuleasrExplorer && viewItem == module",
          "group": "inline"
        },
        {
          "command": "yuleasr.renameModule",
          "when": "view == yuleasrExplorer && viewItem == module",
          "group": "2_modification"
        },
        {
          "command": "yuleasr.deleteModule",
          "when": "view == yuleasrExplorer && viewItem == module",
          "group": "2_modification"
        },
        {
          "command": "yuleasr.validateConfig",
          "when": "view == yuleasrExplorer && viewItem == module",
          "group": "1_validation"
        },
        {
          "command": "yuleasr.generateCode",
          "when": "view == yuleasrExplorer && viewItem == module",
          "group": "1_validation"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "yuleasrExplorer",
          "name": "yuleASR Modules",
          "when": "workspaceHasYuleASR",
          "icon": "$(symbol-misc)"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "yuleasrSidebar",
          "title": "yuleASR",
          "icon": "$(symbol-misc)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "yuleasrExplorer",
        "contents": "No yuleASR configuration found in this workspace.\n[Initialize yuleASR Project](command:yuleasr.initProject)"
      }
    ],
    "languages": [
      {
        "id": "yuleasr-config",
        "aliases": [
          "yuleASR Configuration",
          "yuleasr"
        ],
        "extensions": [
          ".yule.json"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": "*.yule.json",
        "url": "./schemas/module-config.schema.json"
      }
    ],
    "configuration": {
      "title": "yuleASR Configurator",
      "properties": {
        "yuleasr.yuleASRPath": {
          "type": "string",
          "default": "",
          "description": "Path to yuleASR repository"
        },
        "yuleasr.autoSync": {
          "type": "boolean",
          "default": true,
          "description": "Automatically sync with yuleASR repository"
        },
        "yuleasr.validateOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Validate configuration on save"
        },
        "yuleasr.showGeneratedCode": {
          "type": "boolean",
          "default": true,
          "description": "Show generated code preview"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify",
    "dev": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "build:webview": "cd ../yuleasr-web && npx vite build --config vite.config.vscode.ts && cp -r dist-vscode/. ../yuleasr-vscode/media/webview/",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "pnpm build",
    "clean": "rm -rf out",
    "package": "vsce package --no-dependencies",
    "publish-extension": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@yuletech/core": "workspace:*",
    "yuleasr-editor-core": "workspace:*"
  }
}
