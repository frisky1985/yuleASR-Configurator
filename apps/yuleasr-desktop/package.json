{
  "name": "yuleasr-desktop",
  "version": "0.1.0",
  "description": "yuleASR Configurator — Desktop Application",
  "author": "yuleTech <stefan@yuletech.com>",
  "private": true,
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "build": "cd ../yuleasr-web && npx vite build --base ./ && cd ../yuleasr-desktop && cp -r ../yuleasr-web/dist . && electron-builder",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "@yuletech/core": "workspace:*",
    "yuleasr-editor-core": "workspace:*"
  },
  "devDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.40.1",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.yuletech.yuleasr-configurator",
    "productName": "yuleASR Configurator",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
