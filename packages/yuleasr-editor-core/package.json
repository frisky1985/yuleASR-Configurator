{
  "name": "yuleasr-editor-core",
  "version": "0.1.0",
  "description": "Core editor engine for yuleASR configurator",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./models": {
      "import": "./dist/models/index.mjs",
      "require": "./dist/models/index.js",
      "types": "./dist/models/index.d.ts"
    },
    "./engine": {
      "import": "./dist/engine/index.mjs",
      "require": "./dist/engine/index.js",
      "types": "./dist/engine/index.d.ts"
    },
    "./services": {
      "import": "./dist/services/index.mjs",
      "require": "./dist/services/index.js",
      "types": "./dist/services/index.d.ts"
    },
    "./sync": {
      "import": "./dist/sync/index.mjs",
      "require": "./dist/sync/index.js",
      "types": "./dist/sync/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@isomorphic-git/lightning-fs": "^4.6.2",
    "@yuletech/core": "workspace:*",
    "@yuletech/utils": "workspace:*",
    "eventemitter3": "^5.0.1",
    "isomorphic-git": "^1.37.6"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  },
  "files": [
    "dist"
  ]
}
