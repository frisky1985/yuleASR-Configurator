generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String   @unique
  password  String
  avatar    String?
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts    ForumPost[]
  comments ForumComment[]
  blogs    BlogPost[]
  blogComments BlogComment[]
  licenses LicenseKey[]
  templates BSWTemplate[] @relation("BSWTemplateAuthor")
  reviewedTemplates BSWTemplate[] @relation("BSWTemplateReviewer")
}

model ForumPost {
  id        Int      @id @default(autoincrement())
  userId    Int
  configId  Int?
  title     String
  content   String
  tags      String   @default("[]") // JSON array stored as string (SQLite)
  status    String   @default("published")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id])
  comments ForumComment[]
}

model ForumComment {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  content   String
  createdAt DateTime @default(now())

  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id])
}

model BlogPost {
  id           String    @id @default(uuid())
  title        String
  slug         String    @unique
  description  String
  content      String
  authorId     Int
  category     String    @default("全部")
  tags         String    @default("[]") // JSON array as string
  coverImage   String?
  isHot        Boolean   @default(false)
  viewCount    Int       @default(0)
  likeCount    Int       @default(0)
  commentCount Int       @default(0)
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  author   User           @relation(fields: [authorId], references: [id])
  comments BlogComment[]
}

model BlogComment {
  id        String   @id @default(uuid())
  articleId String
  parentId  String?
  content   String
  authorId  Int
  likes     Int      @default(0)
  likedBy   String   @default("[]")
  createdAt DateTime @default(now())

  article BlogPost     @relation(fields: [articleId], references: [id], onDelete: Cascade)
  parent  BlogComment? @relation("BlogCommentReplies", fields: [parentId], references: [id])
  replies BlogComment[] @relation("BlogCommentReplies")
  author  User         @relation(fields: [authorId], references: [id])
}

model Tag {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  postCount Int      @default(0)
  createdAt DateTime @default(now())
}

model LicenseKey {
  id            Int      @id @default(autoincrement())
  key           String   @unique
  tier          String   @default("free") // "free" | "pro"
  maxModules    Int      @default(5)
  maxProjects   Int      @default(1)
  expiresAt     DateTime?
  customerEmail String?
  userId        Int?     // bound to a registered user
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // LemonSqueezy fields
  lemonOrderId    String?  @unique
  lemonCustomerId String?

  user User? @relation(fields: [userId], references: [id])
}

// ── BSW Template Market ──────────────────────────────────────────────────

model BSWTemplate {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  category    String    // mcal | ecual | service | full | bsw
  tags        String    @default("[]")  // JSON array string (SQLite compat)
  moduleType  String?   // Primary layer: MCAL | ECUAL | Service | RTE
  configData  String?   // Full ConfigFile JSON string
  modules     String    @default("[]")  // JSON array of TemplateModule
  version     Int       @default(1)
  downloads   Int       @default(0)
  rating      Int       @default(0)
  isPublic    Boolean   @default(true)
  status      String    @default("published") // draft | published | rejected | archived
  visibility  String    @default("public")  // public | private | team
  isOfficial  Boolean   @default(false)
  minTier     String    @default("free")    // free | pro

  authorId       Int
  author         User         @relation("BSWTemplateAuthor", fields: [authorId], references: [id])
  reviewedById   Int?
  reviewedBy     User?        @relation("BSWTemplateReviewer", fields: [reviewedById], references: [id])

  latestVersionId Int?

  downloadCount  Int  @default(0)
  viewCount      Int  @default(0)
  favoriteCount  Int  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions BSWTemplateVersion[]
}

model BSWTemplateVersion {
  id          Int      @id @default(autoincrement())
  templateId  Int
  template    BSWTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version     Int
  name        String    @default("")
  description String    @default("")
  modules     String    @default("[]")
  configData  String?   // Full ConfigFile JSON string
  changelog   String?
  createdAt   DateTime  @default(now())
}

model PaymentEvent {
  id            Int      @id @default(autoincrement())
  eventId       String   @unique
  type          String   // "payment.success" | "payment.failed"
  email         String?
  licenseKey    String?
  tier          String?
  rawBody       String   // JSON string of the original payload
  processed     Boolean  @default(false)
  createdAt     DateTime @default(now())

  // LemonSqueezy fields
  lemonOrderId    String?
  lemonCustomerId String?
  lemonProductId  String?
  lemonVariantId  String?
}
