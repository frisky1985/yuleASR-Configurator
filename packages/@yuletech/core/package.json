{
  "name": "@yuletech/core",
  "version": "0.1.0",
  "description": "Core types, schemas, and validators for yuleASR configurator",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./src/index.ts"
    },
    "./schema": {
      "import": "./dist/schema/index.mjs",
      "require": "./dist/schema/index.js",
      "types": "./src/schema/index.ts"
    },
    "./schema/generated": {
      "import": "./dist/schema/generated/index.mjs",
      "require": "./dist/schema/generated/index.js",
      "types": "./src/schema/generated/index.ts"
    },
    "./types": {
      "import": "./dist/types/index.mjs",
      "require": "./dist/types/index.js",
      "types": "./src/types/index.ts"
    },
    "./validator": {
      "import": "./dist/validator/index.mjs",
      "require": "./dist/validator/index.js",
      "types": "./src/validator/index.ts"
    },
    "./generator": {
      "import": "./dist/generator/index.mjs",
      "require": "./dist/generator/index.js",
      "types": "./src/generator/index.ts"
    },
    "./schema-extractor": {
      "import": "./dist/schema-extractor/index.mjs",
      "require": "./dist/schema-extractor/index.js",
      "types": "./src/schema-extractor/index.ts"
    },
    "./validators": {
      "import": "./dist/validators/index.mjs",
      "require": "./dist/validators/index.js",
      "types": "./src/validators/index.ts"
    },
    "./conditions": {
      "import": "./dist/conditions/index.mjs",
      "require": "./dist/conditions/index.js",
      "types": "./src/conditions/index.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@yuletech/plugin-sdk": "workspace:*",
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.0"
  },
  "devDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.62.2",
    "@vitest/coverage-v8": "^1.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
