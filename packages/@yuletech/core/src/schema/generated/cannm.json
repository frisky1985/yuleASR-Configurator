{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yuletech.io/schemas/modules/cannm.json",
  "title": "CanNm Configuration",
  "description": "CAN 网络管理",
  "type": "object",
  "properties": {
    "CanNmGeneral": {
      "description": "CanNm 通用配置",
      "type": "object",
      "properties": {
        "CanNmDevErrorDetect": {
          "description": "开启开发错误检测",
          "type": "boolean",
          "default": false
        },
        "CanNmVersionInfoApi": {
          "description": "版本信息API",
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": true
    },
    "CanNmConfigSet": {
      "description": "CanNm 配置集",
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "CanNmGeneral"
  ],
  "additionalProperties": false,
  "x-layer": "ECUAL",
  "x-version": "4.4.0"
}