{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yuletech.io/schemas/modules/bswm.json",
  "title": "BswM Configuration",
  "description": "BSW 模式管理器",
  "type": "object",
  "properties": {
    "BswMGeneral": {
      "description": "BswM 通用配置",
      "type": "object",
      "properties": {
        "BswMDevErrorDetect": {
          "description": "开启开发错误检测",
          "type": "boolean",
          "default": false
        },
        "BswMVersionInfoApi": {
          "description": "版本信息API",
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": true
    },
    "BswMConfigSet": {
      "description": "BswM 配置集",
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "BswMGeneral"
  ],
  "additionalProperties": false,
  "x-layer": "Service",
  "x-version": "4.4.0"
}