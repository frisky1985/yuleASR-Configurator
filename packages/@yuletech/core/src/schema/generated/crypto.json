{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yuletech.io/schemas/modules/crypto.json",
  "title": "Crypto Configuration",
  "description": "硬件加密服务",
  "type": "object",
  "properties": {
    "CryptoGeneral": {
      "description": "Crypto 通用配置",
      "type": "object",
      "properties": {
        "CryptoDevErrorDetect": {
          "description": "开启开发错误检测",
          "type": "boolean",
          "default": false
        },
        "CryptoVersionInfoApi": {
          "description": "版本信息API",
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": true
    },
    "CryptoConfigSet": {
      "description": "Crypto 配置集",
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "CryptoGeneral"
  ],
  "additionalProperties": false,
  "x-layer": "Service",
  "x-version": "4.4.0"
}