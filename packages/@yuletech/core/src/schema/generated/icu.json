{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yuletech.io/schemas/modules/icu.json",
  "title": "Icu Configuration",
  "description": "输入捕捉单元",
  "type": "object",
  "properties": {
    "IcuGeneral": {
      "description": "Icu 通用配置",
      "type": "object",
      "properties": {
        "IcuDevErrorDetect": {
          "description": "开启开发错误检测",
          "type": "boolean",
          "default": false
        },
        "IcuVersionInfoApi": {
          "description": "版本信息API",
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": true
    },
    "IcuConfigSet": {
      "description": "Icu 配置集",
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "IcuGeneral"
  ],
  "additionalProperties": false,
  "x-layer": "MCAL",
  "x-version": "4.4.0"
}