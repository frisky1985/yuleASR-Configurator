{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yuletech.io/schemas/modules/ecum.json",
  "title": "EcuM Configuration",
  "description": "ECU 状态管理器",
  "type": "object",
  "properties": {
    "EcuMGeneral": {
      "description": "EcuM 通用配置",
      "type": "object",
      "properties": {
        "EcuMDevErrorDetect": {
          "description": "开启开发错误检测",
          "type": "boolean",
          "default": false
        },
        "EcuMVersionInfoApi": {
          "description": "版本信息API",
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": true
    },
    "EcuMConfigSet": {
      "description": "EcuM 配置集",
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "EcuMGeneral"
  ],
  "additionalProperties": false,
  "x-layer": "Service",
  "x-version": "4.4.0"
}