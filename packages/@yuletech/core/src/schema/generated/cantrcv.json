{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yuletech.io/schemas/modules/cantrcv.json",
  "title": "CanTrcv Configuration",
  "description": "CAN 收发器",
  "type": "object",
  "properties": {
    "CanTrcvGeneral": {
      "description": "CanTrcv 通用配置",
      "type": "object",
