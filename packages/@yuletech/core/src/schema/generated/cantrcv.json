        "CanTrcvDevErrorDetect": {
          "description": "开启开发错误检测",
          "type": "boolean",
          "default": false
        },
        "CanTrcvVersionInfoApi": {
          "description": "版本信息API",
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": true
    },
    "CanTrcvConfigSet": {
      "description": "CanTrcv 配置集",
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "CanTrcvGeneral"
  ],
  "additionalProperties": false,
  "x-layer": "ECUAL",
  "x-version": "4.4.0"
}