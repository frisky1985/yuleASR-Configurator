{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yuletech.io/schemas/modules/mcl.json",
  "title": "Mcl Configuration",
  "description": "微控制器驱动库",
  "type": "object",
  "properties": {
    "MclGeneral": {
      "description": "Mcl 通用配置",
      "type": "object",
      "properties": {
        "MclDevErrorDetect": {
          "description": "开启开发错误检测",
          "type": "boolean",
          "default": false
        },
        "MclVersionInfoApi": {
          "description": "版本信息API",
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": true
    },
    "MclConfigSet": {
      "description": "Mcl 配置集",
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "MclGeneral"
  ],
  "additionalProperties": false,
  "x-layer": "MCAL",
  "x-version": "4.4.0"
}