{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yuletech.io/schemas/modules/crc.json",
  "title": "Crc Configuration",
  "description": "CRC 计算服务",
  "type": "object",
  "properties": {
    "CrcGeneral": {
      "description": "Crc 通用配置",
      "type": "object",
      "properties": {
        "CrcDevErrorDetect": {
          "description": "开启开发错误检测",
          "type": "boolean",
          "default": false
        },
        "CrcVersionInfoApi": {
          "description": "版本信息API",
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": true
    },
    "CrcConfigSet": {
      "description": "Crc 配置集",
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "CrcGeneral"
  ],
  "additionalProperties": false,
  "x-layer": "Service",
  "x-version": "4.4.0"
}