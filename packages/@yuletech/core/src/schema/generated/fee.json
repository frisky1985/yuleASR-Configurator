{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yuletech.io/schemas/modules/fee.json",
  "title": "Fee Configuration",
  "description": "Flash EEPROM 模拟",
  "type": "object",
  "properties": {
    "FeeGeneral": {
      "description": "Fee 通用配置",
      "type": "object",
      "properties": {
        "FeeDevErrorDetect": {
          "description": "开启开发错误检测",
          "type": "boolean",
          "default": false
        },
        "FeeVersionInfoApi": {
          "description": "版本信息API",
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": true
    },
    "FeeConfigSet": {
      "description": "Fee 配置集",
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "FeeGeneral"
  ],
  "additionalProperties": false,
  "x-layer": "ECUAL",
  "x-version": "4.4.0"
}