{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yuletech.io/schemas/modules/ble.json",
  "title": "Ble Configuration",
  "description": "BLE 驱动",
  "type": "object",
  "properties": {
    "BleGeneral": {
      "description": "Ble 通用配置",
      "type": "object",
      "properties": {
        "BleDevErrorDetect": {
          "description": "开启开发错误检测",
          "type": "boolean",
          "default": false
        },
        "BleVersionInfoApi": {
          "description": "版本信息API",
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": true
    },
    "BleConfigSet": {
      "description": "Ble 配置集",
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "BleGeneral"
  ],
  "additionalProperties": false,
  "x-layer": "ECUAL",
  "x-version": "4.4.0"
}