        "CryIfSupportsCertificateAPI": {
          "type": "boolean",
          "default": false,
          "description": "CryIfSupportsCertificateAPI 参数"
        },
        "CryIfSupportsKeyStatusAPI": {
          "type": "boolean",
          "default": false,
          "description": "CryIfSupportsKeyStatusAPI 参数"
        },
        "CryIfCryptoKeySetValidAPI": {
          "type": "string",
          "maxLength": 255,
          "description": "CryIfCryptoKeySetValidAPI 参数"
        }
      },
      "additionalProperties": true
