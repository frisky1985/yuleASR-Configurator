      "properties": {
        "CryIfKeyId": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535,
          "description": "CryIfKeyId 参数"
        }
      },
      "additionalProperties": true
    },
    "CryIfCryptoModule": {
      "description": "CryIfCryptoModule 配置容器",
      "type": "object",
      "properties": {
        "CryIfSupportsKeyElementCopyPartial": {
          "type": "boolean",
          "default": false,
          "description": "CryIfSupportsKeyElementCopyPartial 参数"
