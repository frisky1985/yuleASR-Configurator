{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yuletech.io/schemas/modules/cryif.json",
  "title": "CryIf Configuration",
  "description": "加密接口",
  "type": "object",
  "properties": {
    "CryIfGeneral": {
      "description": "CryIf 通用配置",
      "type": "object",
      "properties": {
        "CryIfDevErrorDetect": {
          "description": "开启开发错误检测",
          "type": "boolean",
          "default": false
        },
        "CryIfVersionInfoApi": {
          "description": "版本信息API",
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": true
    },
    "CryIfConfigSet": {
      "description": "CryIf 配置集",
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "CryIfGeneral"
  ],
  "additionalProperties": false,
  "x-layer": "Service",
  "x-version": "4.4.0"
}