{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yuletech.io/schemas/modules/cryif.json",
  "title": "CryIf Configuration",
  "description": "加密接口",
  "type": "object",
  "properties": {
    "CryIfChannel": {
      "description": "CryIfChannel 配置容器",
      "type": "object",
      "properties": {
        "CryIfChannelId": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535,
          "description": "CryIfChannelId 参数"
        }
      },
      "additionalProperties": true
    },
    "CryIfGeneral": {
      "description": "CryIfGeneral 配置容器",
      "type": "object",
      "properties": {
        "CryIfDevErrorDetect": {
          "type": "boolean",
          "default": false,
          "description": "CryIfDevErrorDetect 参数"
        },
        "CryIfVersionInfoApi": {
          "type": "boolean",
          "default": false,
          "description": "CryIfVersionInfoApi 参数"
        },
        "CryIfMaxNumberOfKeyElements": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535,
          "description": "CryIfMaxNumberOfKeyElements 参数"
        },
        "CryIfMaxSizeOfKeyElement": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535,
          "description": "CryIfMaxSizeOfKeyElement 参数"
        },
        "CryIfRedirection": {
          "type": "boolean",
          "default": false,
          "description": "CryIfRedirection 参数"
        },
        "CryIfSafeBswChecks": {
          "type": "boolean",
          "default": false,
          "description": "CryIfSafeBswChecks 参数"
        }
      },
      "additionalProperties": true
